      "description": "A new PR-local Rust boundary gap is repairable, commentable, and gate-candidate eligible under explicit policy.",
      "source_artifacts": [
        "target/ripr/reports/repo-exposure.json",
        "target/ripr/review/comments.json",
        "policy/gate.toml"
      ],
      "expected_claim": "New repairable Rust boundary gap with a stable anchor and explicit assertion repair route.",
      "must_not_claim": [
        "runtime mutation proof",
        "coverage adequacy",
        "generic confidence score"
      ],
      "static_unknown_only": false,
      "expected_gap_record": {
        "gap_id": "gap:pr:pricing:threshold-boundary",
        "canonical_gap_id": "gap:rust:pricing:discount:threshold-boundary",
