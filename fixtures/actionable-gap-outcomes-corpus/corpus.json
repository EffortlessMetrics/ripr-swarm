{
  "schema_version": "0.1",
  "kind": "actionable_gap_outcomes_corpus",
  "spec": "RIPR-SPEC-0031",
  "related_spec": "RIPR-SPEC-0057",
  "description": "Fixture-backed actionable gap outcome joins for ripr-swarm repair loop reporting.",
  "limits": [
    "advisory reporting only",
    "no repair execution",
    "no provider calls",
    "no generated tests",
    "no mutation execution",
    "no public badge changes"
